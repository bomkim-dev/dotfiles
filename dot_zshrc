# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/bomkim/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/bomkim/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/bomkim/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/bomkim/google-cloud-sdk/completion.zsh.inc'; fi

# === Ghostty Terminal Setup ===
# Initialized by setup.sh

# source "/Users/bomkim/.config/ghostty-setup/zsh.env"

# Ghostty Terminal Setup - Zsh Configuration
# This file is sourced by .zshrc

# --- zsh-autosuggestions Configuration ---
# Fish-like autosuggestions based on history

# Optimization: Limit buffer size for better performance
# export ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20

# Enable async mode for faster suggestions
# export ZSH_AUTOSUGGEST_USE_ASYNC=1

# Customize suggestion color (subtle gray)
# export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#6c7086"

# Suggest from history and completion
# export ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# --- zsh-syntax-highlighting Configuration ---
# Must be loaded AFTER zsh-autosuggestions
source $HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# loading plugins
eval "$(zoxide init zsh)"
eval "$(atuin init zsh)"
eval "$(starship init zsh)"
eval "$(mise activate zsh)"
eval "$(direnv hook zsh)"
eval "$(fnm env --use-on-cd --shell zsh)"

# --- fzf Configuration ---
# Set up fzf key bindings and fuzzy completion
# Fuzzy finder for files, history, and more
source <(fzf --zsh)

# PET snippet manager
# export PET_CONFIG="$HOME/.config/pet/config.toml"

# Configure fzf
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"
export FZF_ALT_C_OPTS="--preview 'eza --icons --color=always --tree --level=2 {}'"
export FZF_DEFAULT_COMMAND="fd --type f --hidden --follow --exclude '.git'"

# --- delta (Git Pager) Configuration ---
# Syntax highlighting for git diffs - run once on setup, not every shell load
# git config --global core.pager "delta"
# git config --global delta.syntax-theme "gruvbox-dark"
# git config --global delta.line-numbers true
# git config --global delta.side-by-side true

# --- zellij Configuration ---
# Terminal workspace (modern tmux alternative)
# eval "$(zellij setup --generate-completion zsh)"
alias zj='zellij'
alias zja='zellij attach'
alias zjn='zellij new-session -d'

# --- gitui Configuration ---
# Git TUI - fast git UI in Rust
# alias gu='gitui'

# --- procs Configuration ---
# Modern ps replacement
alias ps='procs'

# --- bottom (btm) Configuration ---
# Modern system monitor - run with: btm
alias btm='bottom'

# --- tealdeer Configuration ---
# Fast tldr client - run with: tldr <command>

# --- tokei Configuration ---
# Code statistics - run with: tokei <directory>

# --- ouch Configuration ---
# All-in-one compression tool
alias ouch-decompress='ouch d'
alias ouch-compress='ouch c'

# Use eza instead of ls
alias ls='eza --icons --group-directories-first'
alias ll='eza -l --icons --group-directories-first'
alias la='eza -la --icons --group-directories-first'
alias lt='eza --tree --level=2 --icons'

# General aliases
alias cat='bat --style=auto'
alias find='fd'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Set default editor
export EDITOR='code --wait'
export VISUAL='code --wait'

# Enable color support
# export CLICOLOR=1
# export LSCOLORS=ExFxBxDxCxegedabagacad

# Set language
# export LANG=en_US.UTF-8
# export LC_ALL=en_US.UTF-8

